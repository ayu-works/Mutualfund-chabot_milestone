# Ingest — phase 4.0 (scrape)
INGEST_REGISTRY_PATH=data/registry/urls.yaml
INGEST_RAW_DIR=data/raw
INGEST_USER_AGENT=mf-faq-assistant-ingest/0.1 (+https://github.com/your-org/mf-faq-assistant)
INGEST_RATE_LIMIT_SECONDS=1.5
INGEST_HTTP_TIMEOUT=30
INGEST_HTTP_RETRIES=2
INGEST_MIN_SUCCESS_RATIO=0.8

# Ingest — phase 4.1+ (normalize / chunk / embed / index)
INGEST_NORMALIZED_DIR=data/normalized
INGEST_STRUCTURED_DIR=data/structured
INGEST_CHUNKS_DIR=data/chunks
INGEST_EMBEDDINGS_DIR=data/embeddings
# Chroma Cloud (trychroma.com) — required for phase 4.3 + runtime retriever.
# Get tenant + database from the trychroma.com console; create an API key there.
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_API_KEY=
INGEST_CHROMA_COLLECTION=mf_faq_chunks
EMBED_MODEL_ID=BAAI/bge-small-en-v1.5
EMBED_BATCH_SIZE=32
CHUNK_TARGET_TOKENS=400
CHUNK_MAX_TOKENS=488
CHUNK_OVERLAP_TOKENS=48

# Runtime — generation (phase 6)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Runtime — safety (phase 7)
EDUCATIONAL_URL=https://www.amfiindia.com/investor-corner/investor-center/learn-about-mfs.html

# Runtime — threads (phase 8)
THREAD_DB_PATH=data/threads.sqlite
THREAD_MAX_TURNS=6

# Runtime — API (phase 9)
API_HOST=0.0.0.0
PORT=8000
RUNTIME_API_DEBUG=0
ADMIN_REINDEX_SECRET=
